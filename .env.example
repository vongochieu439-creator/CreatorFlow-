AI_API_BASE_URL=https://your-openai-compatible-endpoint/v1
AI_API_KEY=your_api_key
AI_MODEL=mimo-v2.5-pro
PORT=5173

# 可选：真实发布通道
# 通用 Webhook，适合接自己的自动化服务、低代码发布流或审核后台
PUBLISH_WEBHOOK_URL=
# 也可以按平台单独配置：PUBLISH_WEBHOOK_WECHAT / PUBLISH_WEBHOOK_ZHIHU / PUBLISH_WEBHOOK_BILIBILI / PUBLISH_WEBHOOK_XIAOHONGSHU

# 可选：公众号草稿箱真实接口。需要公众号后台获取 access_token，并先上传封面素材得到 thumb_media_id。
WECHAT_ACCESS_TOKEN=
WECHAT_THUMB_MEDIA_ID=
WECHAT_AUTHOR=CreatorFlow
WECHAT_SOURCE_URL=
